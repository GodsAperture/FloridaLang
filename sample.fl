float8 fun(float8 x){
    for(fixed8 i = 0; i < 3; i = i + 1){
        x = x + 1;
    }

    return x;
}

float8 fun2(float8 x){
    if(x < 0){
        x = -x;
    }

    while(x < 5.0){
        x = 2 * x;
    }
    
    return x;
}

object thing1{
    float8 first;
}

object thing2{
    thing1 first;
    float4 second;
}

object thing3{
    thing1 first;
    thing2 second;
}

thing3 x;